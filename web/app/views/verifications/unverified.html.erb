<% content_for :title, "Verify your email — demucs:r" %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md text-center">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-xl">
      <div class="w-14 h-14 bg-violet-900/30 border border-violet-800/50 rounded-xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-7 h-7 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </div>

      <h1 class="text-xl font-semibold text-white mb-2">Check your inbox</h1>
      <p class="text-slate-400 text-sm mb-6">
        We sent a verification link to <strong class="text-slate-300"><%= current_user.email_address %></strong>.
        Click the link to activate your account.
      </p>

      <%= button_to "Resend verification email", resend_verification_path, method: :post,
          class: "w-full bg-violet-600 hover:bg-violet-500 text-white font-medium text-sm px-5 py-2.5 rounded-lg transition-colors cursor-pointer" %>

      <p class="text-slate-600 text-xs mt-4">
        Wrong email?
        <%= button_to "Sign out", session_path, method: :delete,
            class: "text-violet-500 hover:text-violet-400 text-xs transition-colors cursor-pointer bg-transparent border-0 p-0 inline" %>
        and create a new account.
      </p>
    </div>
  </div>
</div>
