<% content_for :title, "demucs:r – Stem Separator for Producers & DJs | No Subscription" %>
<% content_for :meta_description, "Isolate vocals, bass, drums, and guitar from any song for free. No subscription required. Online stem separator powered by Meta's demucs AI — works on Mac, Windows, Linux, and mobile." %>

<%# JSON-LD Structured Data %>
<% content_for :head do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "demucs:r",
      "url": "https://demucsr.com",
      "description": "Online stem separator that isolates vocals, bass, drums, and guitar from any song. Free, no subscription required.",
      "applicationCategory": "MusicApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free stem separation"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a stem separator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A stem separator is a tool that uses AI to split a mixed song into its individual components — typically vocals, bass, drums, and other instruments. This lets producers, DJs, and musicians work with individual parts of a track for remixing, sampling, or practice."
          }
        },
        {
          "@type": "Question",
          "name": "How does demucs:r work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Upload your audio file and our servers process it using Meta's demucs AI model, returning four isolated WAV stems: bass, drums, vocals, and synth/guitar. It's free."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a subscription?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. demucs:r is completely free to use. There are no fees or commitments."
          }
        },
        {
          "@type": "Question",
          "name": "What audio formats are supported?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "demucs:r accepts WAV, MP3, FLAC, and OGG files up to 500 MB."
          }
        },
        {
          "@type": "Question",
          "name": "What stems does it extract?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Each track is separated into four stems: bass, drums, vocals, and other (synth/guitar). All stems are delivered as high-quality WAV files."
          }
        },
        {
          "@type": "Question",
          "name": "Does it work on mobile and tablet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Because all processing happens on our servers, demucs:r works on any device with a browser — including iPhone, Android, iPad, and tablets. No app installation needed."
          }
        },
        {
          "@type": "Question",
          "name": "How long does stem separation take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Processing typically takes a few minutes depending on the length of the track. You'll receive an email when your stems are ready to download."
          }
        },
        {
          "@type": "Question",
          "name": "How long are stems stored?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Stems are stored in the cloud for 24 hours after processing. Make sure to download them before then."
          }
        },
        {
          "@type": "Question",
          "name": "Does it work on Linux?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. demucs:r is fully browser-based so it works on Linux, Mac, Windows, and any mobile operating system. No native app or Wine required."
          }
        }
      ]
    }
  ]
}
</script>
<% end %>

