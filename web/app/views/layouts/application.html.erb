<!DOCTYPE html>
<html class="h-full" lang="en">
  <head>
    <title><%= content_for(:title) || "demucs:r – Stem Separator for Producers & DJs" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Separate any song into stems — bass, drums, vocals, and guitar — for $1.50 per track. No subscription. Works in the browser on any device." %>">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= request.base_url + request.path %>">

    <%# Open Graph %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="demucs:r">
    <meta property="og:title" content="<%= content_for(:title) || "demucs:r – Stem Separator for Producers & DJs" %>">
    <meta property="og:description" content="<%= content_for(:meta_description) || "Separate any song into stems — bass, drums, vocals, and guitar — for $1.50 per track. No subscription. Works in the browser on any device." %>">
    <meta property="og:url" content="<%= request.base_url + request.path %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app,      "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-slate-950 text-slate-100 antialiased">

    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-4">
        <a href="<%= root_path %>" class="flex items-center gap-2 font-semibold text-white hover:text-violet-400 transition-colors">
          <svg class="w-5 h-5 text-violet-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="13" r="9"/>
            <circle cx="11" cy="13" r="3"/>
            <circle cx="11" cy="13" r="0.5" fill="currentColor" stroke="none"/>
            <line x1="14" y1="10" x2="21" y2="3" stroke-width="2.5"/>
            <line x1="21" y1="3" x2="23" y2="5" stroke-width="2.5"/>
          </svg>
          demucs:r
        </a>
        <span class="text-slate-500 text-sm hidden sm:block">stem creator</span>
        <div class="ml-auto flex items-center gap-4">
          <% if current_user %>
            <span class="hidden sm:block text-slate-400 text-xs truncate max-w-[180px]"><%= current_user.email_address %></span>
            <%= link_to "Account", account_path, class: "text-slate-400 hover:text-white text-xs font-medium transition-colors" %>
            <%= button_to "Sign out", session_path, method: :delete, class: "text-slate-400 hover:text-white text-xs font-medium transition-colors cursor-pointer bg-transparent border-0 p-0" %>
            <%= link_to new_track_path, class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium px-4 py-1.5 rounded-lg transition-colors" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
              </svg>
              Drop a Track
            <% end %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "text-slate-400 hover:text-white text-sm font-medium transition-colors" %>
            <%= link_to "Get Started", new_registration_path, class: "bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium px-4 py-1.5 rounded-lg transition-colors" %>
          <% end %>
        </div>
      </div>
    </header>

    <% if notice %>
      <div class="bg-emerald-900/50 border-b border-emerald-800 text-emerald-300 text-sm px-6 py-3 text-center">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-900/50 border-b border-red-800 text-red-300 text-sm px-6 py-3 text-center">
        <%= alert %>
      </div>
    <% end %>

    <main class="max-w-5xl mx-auto px-6 py-8">
      <%= yield %>
    </main>

    <footer class="border-t border-slate-800 mt-16">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <span class="text-xs text-slate-600">&copy; <%= Date.today.year %> demucs:r</span>
        <%= link_to "Terms & Privacy", legal_path, class: "text-xs text-slate-600 hover:text-slate-400 transition-colors" %>
      </div>
    </footer>

  </body>
</html>
