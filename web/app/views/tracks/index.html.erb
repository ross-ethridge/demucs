<% content_for :title, "Demucs – Tracks" %>

<%= turbo_stream_from :tracks %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-white">Tracks</h1>
    <p class="text-slate-500 text-sm mt-1">Upload audio to separate into stems</p>
  </div>
  <%= link_to new_track_path, class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
    New Track
  <% end %>
</div>

<% if @tracks.empty? %>
  <div class="text-center py-20 border border-dashed border-slate-800 rounded-2xl">
    <div class="w-16 h-16 bg-slate-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
      </svg>
    </div>
    <p class="text-slate-400 font-medium mb-1">No tracks yet</p>
    <p class="text-slate-600 text-sm mb-6">Upload a WAV or MP3 to get started</p>
    <%= link_to "Upload your first track", new_track_path, class: "text-violet-400 hover:text-violet-300 text-sm font-medium transition-colors" %>
  </div>
<% else %>
  <div id="tracks" class="flex flex-col gap-3">
    <%= render @tracks %>
  </div>
<% end %>
