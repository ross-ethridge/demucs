<% content_for :title, "demucs:r – Your Sessions" %>

<%= turbo_stream_from :tracks %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-white">Your Sessions</h1>
    <p class="text-slate-500 text-sm mt-1">Isolate bass, drums, vocals, and synth/guitar from any recording</p>
  </div>
  <%= link_to new_track_path, class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
    Drop a Track
  <% end %>
</div>

<% if @tracks.empty? %>
  <div class="text-center py-20 border border-dashed border-slate-800 rounded-2xl">
    <div class="w-16 h-16 bg-slate-900 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-slate-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="11" cy="13" r="9"/>
        <circle cx="11" cy="13" r="3"/>
        <circle cx="11" cy="13" r="0.5" fill="currentColor" stroke="none"/>
        <line x1="14" y1="10" x2="21" y2="3" stroke-width="2.5"/>
        <line x1="21" y1="3" x2="23" y2="5" stroke-width="2.5"/>
      </svg>
    </div>
    <p class="text-slate-400 font-medium mb-1">No sessions yet</p>
    <p class="text-slate-600 text-sm mb-6">Drop a WAV, MP3, or FLAC and we'll do the rest</p>
    <%= link_to "Drop your first track", new_track_path, class: "text-violet-400 hover:text-violet-300 text-sm font-medium transition-colors" %>
  </div>
<% else %>
  <div class="flex items-center gap-2 bg-amber-900/20 border border-amber-800/50 rounded-lg px-3 py-2 mb-4">
    <svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
    </svg>
    <p class="text-xs text-amber-400">Stems are deleted from cloud storage after 24 hours — download before then.</p>
  </div>
  <div id="tracks" class="flex flex-col gap-3">
    <%= render @tracks %>
  </div>
<% end %>
