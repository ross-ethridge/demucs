<% content_for :title, "#{@track.name} – demucs:r" %>

<%= turbo_stream_from @track %>

<div class="max-w-2xl mx-auto">

  <div class="mb-6">
    <%= link_to tracks_path, class: "inline-flex items-center gap-1.5 text-slate-500 hover:text-slate-300 text-sm transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Your Sessions
    <% end %>
  </div>

  <%= turbo_frame_tag dom_id(@track) do %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">

      <%# Header %>
      <div class="px-6 py-5 border-b border-slate-800 flex items-start justify-between gap-4">
        <div class="min-w-0">
          <h1 class="text-xl font-bold text-white truncate"><%= @track.name %></h1>
          <p class="text-slate-500 text-sm mt-0.5 truncate"><%= @track.filename %></p>
        </div>
        <% badge_classes = case @track.status
           when "pending"    then "bg-amber-900/50 text-amber-400 border-amber-800"
           when "processing" then "bg-blue-900/50 text-blue-400 border-blue-800"
           when "done"       then "bg-emerald-900/50 text-emerald-400 border-emerald-800"
           when "failed"     then "bg-red-900/50 text-red-400 border-red-800"
           end %>
        <span class="flex-shrink-0 inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1 rounded-full border <%= badge_classes %>">
          <%= status_badge_content(@track.status) %>
        </span>
      </div>

      <%# Body %>
      <div class="px-6 py-5">

        <% if @track.status == "done" %>
          <%# Audio player %>
          <div data-controller="audio-player"
               data-audio-player-track-id-value="<%= @track.id %>"
               data-audio-player-stem-value="vocals">

            <audio data-audio-player-target="audio" preload="none"></audio>

            <%# Stem selector tabs %>
            <div class="grid grid-cols-4 gap-2 mb-6">
              <% @track.stems.each do |stem| %>
                <button type="button"
                        data-audio-player-target="stemBtn"
                        data-action="click->audio-player#selectStem"
                        data-audio-player-stem-param="<%= stem %>"
                        data-active="<%= stem == 'vocals' %>"
                        class="group flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl border transition-all
                               data-[active=true]:border-violet-700 data-[active=true]:bg-slate-700/80 data-[active=true]:ring-1 data-[active=true]:ring-violet-500
                               data-[active=false]:border-slate-700 data-[active=false]:bg-slate-800/60 data-[active=false]:hover:bg-slate-700/60">
                  <span class="<%= stem_color(stem) %>"><%= stem_icon(stem, size: "w-6 h-6") %></span>
                  <span class="text-xs font-medium text-slate-300 leading-none"><%= stem == "other" ? "Synth" : stem.capitalize %></span>
                </button>
              <% end %>
            </div>

            <%# Play / pause button %>
            <div class="flex justify-center mb-5">
              <button type="button"
                      data-action="click->audio-player#togglePlay"
                      class="w-14 h-14 rounded-full bg-white hover:scale-105 active:scale-95 transition-transform flex items-center justify-center shadow-lg shadow-black/40">
                <svg data-audio-player-target="playIcon" class="w-6 h-6 text-slate-900 ml-0.5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                <svg data-audio-player-target="pauseIcon" class="w-6 h-6 text-slate-900 hidden" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                </svg>
              </button>
            </div>

            <%# Scrubber %>
            <div class="mb-5">
              <div class="w-full h-1.5 bg-slate-700 rounded-full cursor-pointer"
                   data-audio-player-target="scrubber"
                   data-action="click->audio-player#seek">
                <div class="h-full bg-violet-500 rounded-full pointer-events-none"
                     data-audio-player-target="fill"
                     style="width: 0%"></div>
              </div>
              <div class="flex justify-between text-xs text-slate-500 mt-1.5 tabular-nums">
                <span data-audio-player-target="currentTime">0:00</span>
                <span data-audio-player-target="duration">--:--</span>
              </div>
            </div>

            <%# Volume + download %>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-slate-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
              </svg>
              <input type="range" min="0" max="1" step="0.05" value="1"
                     data-audio-player-target="volume"
                     data-action="input->audio-player#setVolume"
                     class="flex-1 h-1 accent-violet-500 cursor-pointer">
              <button type="button"
                      data-action="click->audio-player#downloadCurrent"
                      class="flex items-center gap-1.5 text-slate-500 hover:text-violet-400 text-sm transition-colors ml-2 flex-shrink-0">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download
              </button>
            </div>

          </div>

        <% elsif @track.status == "processing" %>
          <div class="py-4">
            <div class="flex items-center justify-between text-sm mb-3">
              <span class="text-slate-400">Breaking it down…</span>
              <span class="text-violet-400 font-medium tabular-nums"><%= @track.progress %>%</span>
            </div>
            <div class="w-full bg-slate-800 rounded-full h-2 overflow-hidden">
              <div class="bg-violet-500 h-2 rounded-full transition-all duration-500" style="width: <%= @track.progress %>%"></div>
            </div>
            <p class="text-xs text-slate-600 mt-3 text-center">This page updates automatically when complete</p>
          </div>

        <% elsif @track.status == "pending" %>
          <div class="py-6 text-center">
            <div class="w-12 h-12 bg-slate-800 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-amber-400 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="miter">
                <polygon points="12,2 22,12 12,22 2,12"/>
              </svg>
            </div>
            <p class="text-slate-400 font-medium text-sm">In the queue</p>
            <p class="text-slate-600 text-xs mt-1">This page updates automatically when it starts</p>
          </div>

        <% elsif @track.status == "failed" %>
          <div class="bg-red-900/20 border border-red-900 rounded-xl p-4 text-center">
            <p class="text-red-400 font-medium">Processing failed</p>
            <p class="text-red-600 text-sm mt-1">Check the application logs for details</p>
          </div>
        <% end %>

      </div>

      <%# Footer %>
      <div class="px-6 py-4 border-t border-slate-800 flex items-center justify-between">
        <span class="text-xs text-slate-600">Dropped <%= time_ago_in_words(@track.created_at) %> ago</span>
        <%= button_to track_path(@track), method: :delete,
              class: "inline-flex items-center gap-1.5 text-slate-600 hover:text-red-400 text-sm transition-colors",
              data: { turbo_confirm: "Delete this session and all its stems?" } do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Delete
        <% end %>
      </div>

    </div>
  <% end %>

</div>
