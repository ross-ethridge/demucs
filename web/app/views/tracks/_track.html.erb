<%= turbo_frame_tag dom_id(track) do %>
  <div class="group bg-slate-900 border border-slate-800 hover:border-slate-700 rounded-xl p-4 flex items-center gap-4 transition-colors">

    <%# Icon %>
    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center">
      <svg class="w-5 h-5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="11" cy="13" r="9"/>
        <circle cx="11" cy="13" r="3"/>
        <circle cx="11" cy="13" r="0.5" fill="currentColor" stroke="none"/>
        <line x1="14" y1="10" x2="21" y2="3" stroke-width="2.5"/>
        <line x1="21" y1="3" x2="23" y2="5" stroke-width="2.5"/>
      </svg>
    </div>

    <%# Name + filename %>
    <div class="flex-1 min-w-0">
      <div class="font-medium text-white truncate">
        <%= link_to track.name, track_path(track), class: "hover:text-violet-400 transition-colors" %>
      </div>
      <div class="text-xs text-slate-500 truncate mt-0.5"><%= track.filename %></div>

      <% if track.status == "processing" %>
        <div class="mt-2">
          <div class="w-full bg-slate-800 rounded-full h-1.5 overflow-hidden">
            <div class="bg-violet-500 h-1.5 rounded-full transition-all duration-500" style="width: <%= track.progress %>%"></div>
          </div>
          <div class="text-xs text-slate-500 mt-1"><%= track.progress %>% complete</div>
        </div>
      <% end %>
    </div>

    <%# Status badge %>
    <% badge_classes = case track.status
       when "pending"    then "bg-amber-900/50 text-amber-400 border-amber-800"
       when "processing" then "bg-blue-900/50 text-blue-400 border-blue-800"
       when "done"       then "bg-emerald-900/50 text-emerald-400 border-emerald-800"
       when "failed"     then "bg-red-900/50 text-red-400 border-red-800"
       end %>
    <span class="flex-shrink-0 inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full border <%= badge_classes %>">
      <%= status_badge_content(track.status) %>
    </span>

    <%# Age %>
    <span class="flex-shrink-0 text-xs text-slate-600 hidden sm:block"><%= time_ago_in_words(track.created_at) %> ago</span>

    <%# Delete %>
    <%= button_to track_path(track), method: :delete,
          class: "flex-shrink-0 opacity-0 group-hover:opacity-100 text-slate-600 hover:text-red-400 transition-all p-1 rounded",
          data: { turbo_confirm: "Delete this session and all its stems?" },
          form: { class: "inline" } do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    <% end %>

  </div>
<% end %>
